{
  "name": "git-architect",
  "private": true,
  "version": "0.1.0",
  "description": "Git Architect - Electron + React + TypeScript visual Git repository",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron-forge start & vite dev",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron && npx electron-forge make",
    "start": "npx electron-forge start",
    "make": "npx electron-forge make"
  },
  "dependencies": {
    "core-js": "^3.49.0",
    "framer-motion": "^12.0.0",
    "monaco-editor": "^0.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-flow-renderer": "^10.3.17",
    "react-router-dom": "^6.26.2",
    "reactflow": "^11.11.4",
    "rxjs": "^6.6.7",
    "simple-git": "^3.27.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.2.0",
    "electron-forge": "^5.1.2",
    "electron-prebuilt-compile": "8.2.0",

    "png-to-ico": "^3.0.2",
    "postcss": "^8.4.47",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.6"
  }
}
